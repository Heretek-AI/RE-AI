# =============================================================================
# RE-AI Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your local setup.
#   cp .env.example .env
#
# Settings are loaded by backend/core/config.py (pydantic-settings).
# Any field not set here uses its default from the Settings class.
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
# Host interface to bind to. 127.0.0.1 = local only; 0.0.0.0 = network visible.
HOST=127.0.0.1

# Port the FastAPI/uvicorn server listens on.
PORT=8000

# Enable debug mode (detailed error pages, verbose logging).
DEBUG=True

# ── Database ─────────────────────────────────────────────────────────────────
# Connection string for the main application database (SQLite via aiosqlite).
# Change the filename to use a different database file.
DATABASE_URL=sqlite+aiosqlite:///./re-ai.db

# ── AI Provider ──────────────────────────────────────────────────────────────
# Provider backend: "openai" or "anthropic".
AI_PROVIDER=openai

# API key for the AI provider. Required when using AI-powered features.
# AI_API_KEY=sk-...

# Model identifier for the selected provider.
AI_MODEL=gpt-4o

# ── Vector Database (RAG) ────────────────────────────────────────────────────
# Vector store backend. Currently only "chroma" is supported.
VECTOR_DB_TYPE=chroma

# Directory where ChromaDB persists its index data.
CHROMA_PERSIST_DIR=./.chroma
